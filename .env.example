# FlashForge Environment Configuration
# Copy this file to .env and fill in your API keys

# ============================================
# Swarm Coordination (FoxMQ — MQTT 5.0 + Vertex BFT)
# ============================================

# Shared HMAC-SHA256 secret — must be identical on all nodes
SWARM_SECRET=change-me-to-a-strong-random-secret

# FoxMQ broker address (default: local broker on port 1883)
# Docker Compose sets FOXMQ_HOST=foxmq automatically
FOXMQ_HOST=127.0.0.1
FOXMQ_PORT=1883

# Directory for Proof of Coordination JSONL logs
POC_LOG_DIR=./poc_logs

# Directory for generated output (HTML, ZIP)
OUTPUT_DIR=./swarm_output

# ============================================
# LLM API Keys
# ============================================

# Groq API Key (Primary LLM — planner, FREE)
# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (Quality LLM — builder, FREE)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# DeepSeek API Key (Fallback LLM — cheap ~$0.002/build)
# Get from: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Anthropic API Key (Last resort — highest quality)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================
# Optional: Custom Model Selection
# ============================================

# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-2.5-flash
# DEEPSEEK_MODEL=deepseek-chat
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ============================================
# Optional: Quality Thresholds
# ============================================

# Minimum critic score to skip fixer (0-100, default 75)
# PASS_THRESHOLD=75

# Max tokens per generation
# MAX_TOKENS=32000

# Max retry attempts for fixes
# MAX_RETRY_ATTEMPTS=3

# ============================================
# Optional: Debug
# ============================================

# DEBUG=false
# LOG_LEVEL=INFO
